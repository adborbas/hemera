default_platform(:ios)

XCCONFIG = "Config/Shared.xcconfig".freeze
BETA_GROUP = "Testers (all builds)".freeze # internal group set to auto-receive all builds

platform :ios do
  # ---------------------------------------------------------------------------
  # 1. Cut a new release
  #    Branch release/<version> from main, then advance main to the next
  #    development version so main never sits on a released version and always
  #    stays ahead of the release branch. main normally already holds <version>
  #    (it tracks the in-development version), so the release branch just pins it.
  #    The main advance goes through an auto-merged PR (main is protected), so
  #    GH_TOKEN must be a PAT with admin rights — see RELEASING.md.
  #    Usage: bundle exec fastlane cut_release version:1.4.0
  # ---------------------------------------------------------------------------
  desc "Cut a release branch and advance main to the next development version"
  lane :cut_release do |options|
    version = options[:version] or UI.user_error!("Missing `version:` (e.g. version:1.4.0)")
    branch = "release/#{version}"
    next_version = next_minor_version(version)

    ensure_git_status_clean
    sh("git", "fetch", "origin", "main")

    # Create the release branch, pinned at <version>. main normally already holds
    # this version, so this is usually a no-op; record it only if it differs.
    sh("git", "checkout", "-B", branch, "origin/main")
    if get_xcconfig_value(key: "MARKETING_VERSION") != version
      set_xcconfig_value(key: "MARKETING_VERSION", value: version)
      git_commit(path: XCCONFIG, message: "Prepare release #{version}")
    end
    push_to_git_remote(local_branch: branch, remote_branch: branch, force: false)

    # Advance main to the next development version. main is protected: direct
    # pushes are rejected (changes must go through a PR), so the bump goes on a
    # short-lived branch that is opened as a PR and admin-merged. Opening the PR
    # satisfies the non-bypassable "changes via PR" rule; admin-merge bypasses the
    # required review and "Unit Tests" check (enforce_admins is off) for this
    # trivial one-line bump. This requires GH_TOKEN to be a PAT with admin rights
    # — the default Actions token is write-only and cannot admin-merge.
    bump_branch = "chore/bump-main-#{next_version}"
    sh("git", "checkout", "-B", bump_branch, "origin/main")
    set_xcconfig_value(key: "MARKETING_VERSION", value: next_version)
    git_commit(path: XCCONFIG, message: "Bump main to #{next_version} for development")
    push_to_git_remote(local_branch: bump_branch, remote_branch: bump_branch, force: false)

    sh(
      "gh", "pr", "create",
      "--base", "main",
      "--head", bump_branch,
      "--title", "Bump main to #{next_version} for development",
      "--body", "Advance main to the next in-development version after cutting #{branch}."
    )
    sh("gh", "pr", "merge", bump_branch, "--squash", "--admin", "--delete-branch")

    UI.success("Cut #{branch} at #{version}; advanced main to #{next_version} via an auto-merged PR. Run the Upload to TestFlight lane next.")
  end

  # ---------------------------------------------------------------------------
  # 2. Upload a release build to TestFlight
  #    Signs via match, bumps the build number, archives, uploads.
  #    Usage: bundle exec fastlane beta
  # ---------------------------------------------------------------------------
  desc "Build a signed release and upload it to TestFlight"
  lane :beta do
    # On CI there is no interactive login keychain, so match can't set the key
    # partition list on the runner's login keychain (no password), leaving
    # codesign blocked on a UI authorization prompt that never comes (the job
    # then hangs until the timeout). setup_ci creates a dedicated temporary
    # keychain with a known password that match imports into and codesign uses
    # non-interactively. It is a no-op when running locally.
    setup_ci

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: true,
      in_house: false
    )

    # Fail fast (before the slow archive) if MARKETING_VERSION is already
    # released: its TestFlight train is closed, so the upload would be rejected.
    # Bumping the marketing version is a once-per-release decision — run
    # `fastlane cut_release version:<next>` instead.
    ensure_open_version_train!

    match(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    # Unique build number per upload: highest TestFlight build for this version + 1.
    next_build = latest_testflight_build_number(
      api_key: api_key,
      initial_build_number: 0
    ) + 1
    set_xcconfig_value(key: "CURRENT_PROJECT_VERSION", value: next_build.to_s)

    # The project uses automatic signing for local development, but on CI there's
    # no Apple account to resolve a profile, so the archive must use manual
    # signing with the match-installed distribution profile. Scoped to the
    # Release configuration so Debug/local automatic signing is untouched.
    profile_name = ENV.fetch("sigh_com.adborbas.hemera.app_appstore_profile-name")
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Hemera.xcodeproj",
      targets: ["Hemera"],
      build_configurations: ["Release"],
      code_sign_identity: "Apple Distribution",
      profile_name: profile_name
    )

    build_app(
      project: "Hemera.xcodeproj",
      scheme: "Hemera",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          # match sets this env var to the exact profile name it installed.
          "com.adborbas.hemera.app" => ENV["sigh_com.adborbas.hemera.app_appstore_profile-name"]
        }
      }
    )

    # Upload and return immediately — do NOT wait for App Store Connect to
    # finish processing. Waiting is a well-known source of CI hangs (pilot polls
    # the oldest processing build, not the one just uploaded), and it's the only
    # reason the job needs to wait at all. Distribution to internal testers is
    # decoupled: the "Testers" group has access to all builds, so every build is
    # delivered automatically once Apple finishes processing it — no in-lane
    # group assignment (which would force the wait) required.
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )

    UI.success("Uploaded build #{next_build} to TestFlight. It will reach the '#{BETA_GROUP}' group once App Store Connect finishes processing it.")
  end

  # ---------------------------------------------------------------------------
  # 3. Publish a release
  #    Tag the release branch, create a GitHub release, merge back to main.
  #    Usage: bundle exec fastlane publish version:1.3.0
  # ---------------------------------------------------------------------------
  desc "Tag, create a GitHub release, and merge the release branch back to main"
  lane :publish do |options|
    version = options[:version] or UI.user_error!("Missing `version:` (e.g. version:1.3.0)")
    branch = "release/#{version}"
    tag = "v#{version}"

    ensure_git_status_clean
    sh("git", "fetch", "origin", branch, "main")
    sh("git", "checkout", branch)
    sh("git", "reset", "--hard", "origin/#{branch}")

    add_git_tag(tag: tag)
    push_git_tags(tag: tag)

    sh("gh", "release", "create", tag, "--title", version, "--notes", "Release #{version}")

    # Open a PR to merge the release branch back into main — but only if the
    # branch has commits main doesn't already have (e.g. fixes made during
    # review). With the version pinned by branching rather than a commit, a clean
    # release often has nothing to merge back. Merging the PR (and deleting the
    # branch) is a manual step so it respects branch protection.
    behind = sh("git", "rev-list", "--count", "origin/main..origin/#{branch}").strip.to_i
    if behind.zero?
      UI.success("Published #{tag}. No release-branch changes to merge back to main.")
    else
      sh(
        "gh", "pr", "create",
        "--base", "main",
        "--head", branch,
        "--title", "Merge #{branch} back to main",
        "--body", "Back-merge of the shipped #{tag} release into main."
      )
      UI.success("Published #{tag}. Opened a back-merge PR for #{branch} → main.")
    end
  end

  # ---------------------------------------------------------------------------
  # 4. Prepare an App Store version for review
  #    Creates/updates the App Store version, attaches the latest processed
  #    build, sets the release notes (from fastlane/metadata), and marks it for
  #    automatic release — everything except the final Submit, which stays a
  #    manual click in App Store Connect.
  #    Usage: bundle exec fastlane prepare_release [version:1.4.0] [build:12]
  #    version defaults to the branch MARKETING_VERSION; build to the latest.
  # ---------------------------------------------------------------------------
  desc "Prepare an App Store version for review (does not submit)"
  lane :prepare_release do |options|
    version = options[:version]
    version = nil if version.to_s.strip.empty?
    version ||= get_xcconfig_value(key: "MARKETING_VERSION")

    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_content: ENV.fetch("ASC_KEY_P8"),
      is_key_content_base64: true,
      in_house: false
    )

    # Attach a specific build if given, otherwise the latest build already
    # uploaded to TestFlight for this version.
    build_number = options[:build]
    build_number = nil if build_number.to_s.strip.empty?
    build_number ||= latest_testflight_build_number(api_key: api_key, version: version)

    deliver(
      api_key: api_key,
      app_version: version,
      build_number: build_number.to_s,
      skip_binary_upload: true,   # the build is uploaded by the beta lane
      skip_screenshots: true,     # screenshots are managed manually in ASC
      skip_metadata: false,       # push release_notes from fastlane/metadata
      automatic_release: true,    # go live automatically once approved
      submit_for_review: false,   # prepare only — submit stays a manual step
      run_precheck_before_submit: false,
      force: true                 # no interactive HTML preview on CI
    )

    UI.success("Prepared App Store version #{version} (build #{build_number}) for review. Submit it in App Store Connect when ready.")
  end
end

# Set a KEY = VALUE line in Config/Shared.xcconfig in place.
def set_xcconfig_value(key:, value:)
  path = File.expand_path("../#{XCCONFIG}", __dir__)
  contents = File.read(path)
  updated = contents.gsub(/^#{Regexp.escape(key)}\s*=.*$/, "#{key} = #{value}")
  UI.user_error!("`#{key}` not found in #{XCCONFIG}") if updated == contents
  File.write(path, updated)
  UI.message("Set #{key} = #{value} in #{XCCONFIG}")
end

# Next development version: bump the minor, reset the patch.
# "1.4.0" -> "1.5.0", "1.4" -> "1.5.0".
def next_minor_version(version)
  major, minor, = version.split(".").map(&:to_i)
  "#{major || 0}.#{(minor || 0) + 1}.0"
end

# Read a KEY's value from Config/Shared.xcconfig.
def get_xcconfig_value(key:)
  path = File.expand_path("../#{XCCONFIG}", __dir__)
  match = File.read(path).match(/^#{Regexp.escape(key)}\s*=\s*(.+)$/)
  UI.user_error!("`#{key}` not found in #{XCCONFIG}") if match.nil?
  match[1].strip
end

# Fail if MARKETING_VERSION is already released on the App Store — its
# TestFlight train is closed for new builds. Requires that spaceship is already
# authenticated (app_store_connect_api_key sets its token by default).
def ensure_open_version_train!
  marketing_version = get_xcconfig_value(key: "MARKETING_VERSION")
  app = Spaceship::ConnectAPI::App.find("com.adborbas.hemera.app")
  UI.user_error!("Could not find app com.adborbas.hemera.app on App Store Connect") if app.nil?

  live = app.get_live_app_store_version
  return if live.nil? # nothing released yet — any version is open

  if Gem::Version.new(marketing_version) <= Gem::Version.new(live.version_string)
    UI.user_error!(
      "MARKETING_VERSION #{marketing_version} is already released (live: #{live.version_string}). " \
      "Its TestFlight train is closed for new builds. " \
      "Run `fastlane cut_release version:<next>` to bump the marketing version first."
    )
  end
end
